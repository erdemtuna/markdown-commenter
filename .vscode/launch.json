{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },
    {
      "name": "Launch Extension (No Other Extensions)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--skip-release-notes",
        "--skip-welcome"
      ],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },
    {
      "name": "Launch Tests",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test"
      ],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    }
  ]
}
